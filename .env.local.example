# Sanity — copy this file to .env.local and fill in the values from
# https://www.sanity.io/manage (Project → API / Project settings).
# Until NEXT_PUBLIC_SANITY_PROJECT_ID is set, the site renders placeholder
# content and /studio shows a configuration notice.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# YouTube Data API v3 key for the homepage video feed. Server-side only —
# do NOT prefix with NEXT_PUBLIC. Create at https://console.cloud.google.com
# (enable "YouTube Data API v3" → Credentials → API key).
YOUTUBE_API_KEY=

# Resend API key for the contact form. Server-side only. Create at
# https://resend.com (API Keys). The sending domain must be verified in Resend.
RESEND_API_KEY=
# Optional: override the contact form's "from" address (must be on a verified
# Resend domain). Defaults to "ThaiSide Rens Website <contact@thaisiderens.nl>".
# CONTACT_FROM_EMAIL=
# Optional: override the contact form's recipient. Defaults to
# rens@thaisiderens.nl. Handy for redirecting mail in staging/testing.
# CONTACT_TO_EMAIL=
